rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /makers/{makerId} {
      allow read: if resource.data.status == "Published" || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /enquiries/{enquiryId} {
      allow create: if
        request.resource.data.keys().hasOnly([
          "name",
          "email",
          "interest",
          "source",
          "status",
          "createdAt"
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 2
        && request.resource.data.name.size() <= 120
        && request.resource.data.email is string
        && request.resource.data.email.size() <= 240
        && request.resource.data.interest is string
        && request.resource.data.interest.size() <= 500
        && request.resource.data.status == "new";
      allow read, update, delete: if isAdmin();
    }

    match /updates/{updateId} {
      allow read: if resource.data.status == "published" || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /siteContent/{contentId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if signedIn() && request.auth.uid == adminId;
      allow write: if false;
    }
  }
}
